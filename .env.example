# Copy this file to .env and fill in your keys.

# HubSpot Private App Token (CRM read access required)
HUBSPOT_API_KEY=pat-eu1-7421fb15-5e8a-4bbc-a5ba-c439215eee36

# Similarweb API Key (Digital Data API)
SIMILARWEB_API_KEY=sw-xxxxxxxxxxxxxxxxxxxxxxxx

# SERP API Key (optional — for competitor / checkout enrichment)
SERP_API_KEY=

# Meta Graph API Token (optional — for ad-spend checks)
META_ACCESS_TOKEN=

# Defaults
DEFAULT_COUNTRY=ES
HUBSPOT_CROSS_COUNTRY_PROPERTY=cross_country_flag
